# 应用配置
NODE_ENV=development
PORT=3000
API_BASE_URL=http://localhost:3000/api/v1

# 数据库配置（密码需与 docker-compose 里 POSTGRES_PASSWORD 一致，默认 postgres）
# Windows 若本机已装 Postgres 占 5432，可在 .env 加 POSTGRES_PUBLISH_PORT=5433，并写 DATABASE_URL=...@localhost:5433/...
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/gespace?schema=public

# Redis 配置
REDIS_URL=redis://localhost:6379

# JWT 配置
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=2h
JWT_REFRESH_EXPIRES_IN=7d

# Judge0 配置
JUDGE0_URL=http://localhost:2358

# 日志配置
LOG_LEVEL=info

# CORS 配置
CORS_ORIGIN=http://localhost:5173

# Redis Key 前缀
REDIS_KEY_PREFIX=gesp:

# 缓存 TTL (秒)
CACHE_TTL_DAILY_QUESTIONS=86400
CACHE_TTL_USER_STATS=300
CACHE_TTL_QUESTION_DETAIL=3600
CACHE_TTL_KNOWLEDGE_TREE=86400
